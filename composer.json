{
    "name": "markhadjar/wp-config",
    "description": "Define WordPress constants using environment variables.",
    "type": "library",
    "keywords": ["configuration", "wordpress", "wp-config"],
    "license": "MIT",
    "authors": [
        {
            "name": "Mark Hadjar",
            "email": "hello@markhadjar.com"
        }
    ],
    "support": {
        "issues": "https://github.com/markhadjar/wp-config/issues",
        "source": "https://github.com/markhadjar/wp-config"
    },
    "require": {
        "php": "^8.4",
        "markhadjar/env": "^1.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "MarkHadjar\\WpConfig\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MarkHadjar\\WpConfig\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "analyze": "phpstan analyse --memory-limit=256M",
        "check": [
            "composer validate --strict",
            "@cs-check",
            "@analyze",
            "@test"
        ],
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "test": "phpunit",
        "test-coverage-html": "phpunit --coverage-html build/reports/phpunit/html/",
        "test-unit": "phpunit --testsuite unit"
    }
}
